# Copy this file to ".env" in the backend/ folder and adjust as needed.
# The app works with zero changes to this file for local/demo use.

SECRET_KEY=dev-secret-key-change-me-in-production-32chars
JWT_SECRET_KEY=dev-jwt-secret-change-me-in-production-32chars

# Default: SQLite (no setup needed). To use MySQL instead, uncomment and edit:
# DATABASE_URL=mysql+pymysql://root:password@localhost/food_donation
